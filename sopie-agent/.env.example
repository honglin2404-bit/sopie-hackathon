# Node 3 — reason: strongest model, critical decision node
LLM_MODEL_REASON=minimax/minimax-m2.5

# Node 4 — generate_response: Vietnamese text generation
LLM_MODEL_GEN=google/gemma-4-31b-it

SUPABASE_URL=https://your-project.supabase.co
OPENAI_API_KEY=sk-...your_openai_api_key_for_embeddings
